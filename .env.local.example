# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin API Protection ────────────────────────────────────────────────────
# Set a strong random secret. Admin API routes check for this in the
# X-Admin-Key header. In development mode, this is bypassed with a warning.
ADMIN_API_SECRET=change-me-to-a-strong-random-secret

# ─── Email Notifications (Resend) ────────────────────────────────────────────
# Optional. Sign up at resend.com — free tier is enough for internal use.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=your-admin-email@company.com

# ─── App URL ─────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
